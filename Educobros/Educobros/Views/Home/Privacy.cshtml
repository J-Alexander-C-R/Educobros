@{
    ViewData["Title"] = "Privacidad";
}

<div class="main-card" style="max-width: 800px; margin: 0 auto;">
    <span class="section-badge">Legal</span>
    <h1 class="page-title mt-2 mb-1">Política de Privacidad</h1>
    <div class="divider-red"></div>

    <p class="mt-4" style="color:var(--gris-texto); line-height:1.8;">
        EduCobros es un sistema de gestión escolar privado. Toda la información registrada
        en esta plataforma, incluyendo datos de estudiantes y pagos, es confidencial y de
        uso exclusivo del personal autorizado del centro educativo.
    </p>
    <p style="color:var(--gris-texto); line-height:1.8;">
        No se comparte información con terceros. El acceso al sistema está protegido
        por autenticación y roles de usuario.
    </p>
</div>