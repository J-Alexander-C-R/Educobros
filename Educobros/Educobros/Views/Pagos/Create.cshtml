@model EduCobros.Models.Pago

@{
    ViewData["Title"] = "Registrar Pago";
}

<div class="main-card card-accent" style="max-width: 720px; margin: 0 auto;">
    <span class="section-badge">Nuevo registro</span>
    <h1 class="page-title mt-2 mb-1">Registrar Pago</h1>
    <p class="page-subtitle mb-4">Selecciona el estudiante y completa los datos del pago.</p>
    <div class="divider-red"></div>

    <form asp-action="Create" method="post" class="mt-4">
        @Html.AntiForgeryToken()
        <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3"></div>

        <div class="mb-3">
            <label asp-for="EstudianteId" class="form-label"></label>
            <select asp-for="EstudianteId" class="form-select" asp-items="ViewBag.EstudianteId">
                <option value="">— Selecciona un estudiante —</option>
            </select>
            <span asp-validation-for="EstudianteId" class="text-danger"></span>
        </div>

        <div class="mb-3">
            <label asp-for="Concepto" class="form-label"></label>
            <input asp-for="Concepto" class="form-control" placeholder="Ej: Mensualidad de mayo" />
            <span asp-validation-for="Concepto" class="text-danger"></span>
        </div>

        <div class="row">
            <div class="col-md-6 mb-3">
                <label asp-for="Monto" class="form-label"></label>
                <input asp-for="Monto" class="form-control" type="number" step="0.01" placeholder="0.00" />
                <span asp-validation-for="Monto" class="text-danger"></span>
            </div>
            <div class="col-md-6 mb-3">
                <label asp-for="Fecha" class="form-label"></label>
                <input asp-for="Fecha" class="form-control" type="date" value="@Model?.Fecha.ToString("yyyy-MM-dd")" />
                <span asp-validation-for="Fecha" class="text-danger"></span>
            </div>
        </div>

        <div class="mb-3">
            <label asp-for="Metodo" class="form-label"></label>
            <select asp-for="Metodo" class="form-select">
                <option value="">— Selecciona un método —</option>
                <option>Efectivo</option>
                <option>Transferencia</option>
                <option>Tarjeta</option>
                <option>Depósito</option>
            </select>
            <span asp-validation-for="Metodo" class="text-danger"></span>
        </div>

        <div class="mb-4">
            <label asp-for="Notas" class="form-label"></label>
            <textarea asp-for="Notas" class="form-control" rows="3" placeholder="Notas adicionales (opcional)"></textarea>
            <span asp-validation-for="Notas" class="text-danger"></span>
        </div>

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-main">Guardar Pago</button>
            <a asp-action="Index" class="btn btn-secondary">Cancelar</a>
        </div>
    </form>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}