@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="main-card card-accent" style="max-width: 680px; margin: 0 auto;">
    <span class="section-badge">Error del sistema</span>
    <h1 class="page-title mt-2 mb-1" style="color:var(--rojo)">Algo salió mal</h1>
    <p class="page-subtitle mb-4">Ocurrió un error al procesar tu solicitud.</p>
    <div class="divider-red"></div>

    @if (Model.ShowRequestId)
    {
        <p class="mt-4" style="font-size:0.88rem; color:var(--gris-texto);">
            <strong>Request ID:</strong> <code>@Model.RequestId</code>
        </p>
    }

    <p class="mt-3" style="color:var(--gris-texto); font-size:0.92rem;">
        Si el problema persiste, contacta al administrador del sistema.
    </p>

    <div class="mt-4">
        <a asp-controller="Home" asp-action="Index" class="btn btn-main">Volver al inicio</a>
    </div>
</div>